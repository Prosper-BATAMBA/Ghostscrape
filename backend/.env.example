# GhostScrape Backend Configuration

# Database
DATABASE_URL=postgresql+psycopg2://ghostscrape:ghostscrape_secret@localhost:5432/ghostscrape

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change_this_to_a_random_secret_key

# Scrapy
CONCURRENT_REQUESTS=4
DOWNLOAD_DELAY=2.0
SCRAPE_TIMEOUT=30

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
